page {
  width: 100vw;
  max-width: 100vw;
  min-height: 100%;
  overflow-x: hidden;
  background: #f7fafb;
  color: #141821;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
picker,
image,
scroll-view,
canvas {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  border-radius: 0;
  background: transparent;
}

button::after {
  border: 0;
}

button[disabled] {
  opacity: 0.48;
}

.page {
  min-height: 100vh;
  padding: 36rpx 30rpx 60rpx;
  background: #f7fafb;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.title {
  color: #141821;
  font-size: 50rpx;
  font-weight: 760;
  line-height: 1.12;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 10rpx;
  color: #66717d;
  font-size: 24rpx;
  line-height: 1.5;
}

.primary-btn,
.secondary-btn,
.ghost-btn,
.danger-btn {
  min-height: 76rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.primary-btn {
  background: #141821;
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(20, 24, 33, 0.14);
}

.secondary-btn {
  border: 2rpx solid #e1e9ee;
  background: #ffffff;
  color: #141821;
}

.ghost-btn {
  border: 2rpx solid #dbe4e7;
  color: #141821;
}

.danger-btn {
  background: #f9e9e6;
  color: #9f5d50;
}

.panel {
  background: #ffffff;
  border: 2rpx solid #e1e9ee;
  border-radius: 30rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(20, 24, 33, 0.06);
}

.section {
  margin-top: 26rpx;
}

.section-title {
  margin-bottom: 18rpx;
  color: #141821;
  font-size: 32rpx;
  font-weight: 760;
  line-height: 1.25;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  min-height: 58rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #66717d;
  font-size: 24rpx;
}

.chip.active {
  border-color: #141821;
  background: #141821;
  color: #ffffff;
  font-weight: 700;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #66717d;
  font-size: 24rpx;
}

.input {
  width: 100%;
  min-height: 82rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 24rpx;
  padding: 0 22rpx;
  background: #ffffff;
  color: #141821;
}

.empty {
  padding: 96rpx 34rpx;
  border-radius: 30rpx;
  background: #eef5f7;
  color: #66717d;
  line-height: 1.65;
  text-align: center;
}

.muted {
  color: #66717d;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}


