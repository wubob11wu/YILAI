page {
  min-height: 100%;
  background: #f6f2ea;
  color: #1d1c1a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
picker,
image {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  border-radius: 0;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  padding: 32rpx 28rpx 52rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 8rpx;
  color: #817b70;
  font-size: 24rpx;
}

.primary-btn,
.secondary-btn,
.ghost-btn,
.danger-btn {
  min-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 6rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.primary-btn {
  background: #1d1c1a;
  color: #ffffff;
}

.secondary-btn {
  background: #ece3d2;
  color: #1d1c1a;
}

.ghost-btn {
  border: 2rpx solid #d8d0c2;
  color: #34312d;
}

.danger-btn {
  background: #f0ded8;
  color: #8d3b2f;
}

.panel {
  background: #fffdfa;
  border: 2rpx solid #e2d9ca;
  border-radius: 6rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(50, 42, 31, 0.05);
}

.section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  min-height: 56rpx;
  padding: 0 20rpx;
  border: 2rpx solid #ded4c4;
  border-radius: 6rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #5a554c;
  font-size: 24rpx;
}

.chip.active {
  border-color: #1d1c1a;
  background: #1d1c1a;
  color: #fffdfa;
  font-weight: 700;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  color: #746d63;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  min-height: 76rpx;
  border: 2rpx solid #ded4c4;
  border-radius: 6rpx;
  padding: 0 20rpx;
  background: #fffdfa;
}

.empty {
  padding: 72rpx 28rpx;
  text-align: center;
  color: #817b70;
}

.muted {
  color: #817b70;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}
