.batch-page {
  min-height: 100vh;
  padding: 34rpx 30rpx 0;
  background: #f7fafb;
}

.batch-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.choose-btn {
  min-width: 156rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #141821;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 760;
}

.limit-text {
  width: fit-content;
  margin-top: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fffaf0;
  color: #7b652d;
  font-size: 22rpx;
  font-weight: 760;
}

.progress-card,
.editor-card {
  margin-top: 22rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(20, 24, 33, 0.06);
}

.progress-card {
  padding: 24rpx;
  color: #141821;
  font-size: 27rpx;
  font-weight: 760;
}

.quick-actions {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.quick-actions button {
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef5f7;
  color: #141821;
  font-size: 24rpx;
  font-weight: 760;
}

.draft-strip {
  margin: 22rpx -30rpx 0;
  padding-left: 30rpx;
  white-space: nowrap;
}

.draft-row {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 30rpx;
}

.draft-thumb {
  position: relative;
  width: 118rpx;
  height: 118rpx;
  border: 4rpx solid transparent;
  border-radius: 28rpx;
  overflow: hidden;
  background: #eef5f7;
}

.draft-thumb.active {
  border-color: #141821;
}

.draft-thumb.done::after {
  content: "";
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d8b96a;
}

.draft-thumb image {
  width: 100%;
  height: 100%;
}

.editor-card {
  padding: 24rpx;
}

.hero-image {
  width: 100%;
  height: 520rpx;
  border-radius: 30rpx;
  background: #eef5f7;
}

.field-block {
  margin-top: 26rpx;
}

.field-title {
  margin-bottom: 14rpx;
  color: #66717d;
  font-size: 24rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.select-chip {
  min-height: 60rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #66717d;
  font-size: 23rpx;
  font-weight: 760;
}

.select-chip.active {
  border-color: #141821;
  background: #141821;
  color: #ffffff;
}

.name-input {
  width: 100%;
  height: 84rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 24rpx;
  background: #ffffff;
  color: #141821;
  font-size: 26rpx;
}

.complete-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #141821;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.empty {
  margin-top: 24rpx;
}

.bottom-space {
  height: 136rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
  padding: 18rpx 30rpx 30rpx;
  background: rgba(248, 251, 252, 0.96);
  border-top: 2rpx solid rgba(225, 233, 238, 0.78);
}

.save-all-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #141821;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 800;
}

