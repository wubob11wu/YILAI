<view class="calendar-page">
  <view class="calendar-header">
    <view>
      <view class="title">穿搭日历</view>
      <view class="subtitle">点击日期查看当天穿搭</view>
    </view>
  </view>

  <view class="month-card">
    <view class="month-nav">
      <button class="month-btn" bindtap="prevMonth">‹</button>
      <view class="month-title">{{monthTitle}}</view>
      <button class="month-btn" bindtap="nextMonth">›</button>
    </view>

    <view class="week-row">
      <view wx:for="{{weekDays}}" wx:key="*this" class="week-cell">{{item}}</view>
    </view>

    <view class="day-grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="key"
        class="day-cell {{item.empty ? 'empty-cell' : ''}} {{item.active ? 'active' : ''}} {{item.today ? 'today' : ''}}"
        data-date="{{item.date}}"
        bindtap="selectDate"
      >
        <text wx:if="{{!item.empty}}">{{item.day}}</text>
        <view wx:if="{{item.hasRecord}}" class="record-dot"></view>
      </view>
    </view>
  </view>

  <view class="detail-card">
    <view class="detail-top">
      <view>
        <view class="detail-date">{{selectedDate}}</view>
        <view class="detail-summary">{{selectedSummary}}</view>
      </view>
    </view>

    <canvas class="outfit-canvas" canvas-id="outfitCanvas"></canvas>

    <view wx:if="{{privacy.hideOutfitRecords}}" class="empty-text">穿搭记录已隐藏。</view>
    <view wx:elif="{{selectedOutfits.length}}" class="record-list">
      <view wx:for="{{selectedOutfits}}" wx:key="id" class="record-item">
        <view class="record-main">{{item.names}}</view>
        <view class="record-meta">{{item.sceneText}} · {{item.weatherText}} · {{item.palette}}</view>
      </view>
    </view>
    <view wx:else class="empty-text">这一天还没有记录。去推荐页确认一套穿搭后，这里会实时生成穿搭图片。</view>
  </view>
</view>
