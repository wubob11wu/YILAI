.calendar-page {
  min-height: 100vh;
  padding: 34rpx 30rpx 64rpx;
  background: #f7fafb;
}

.calendar-header {
  margin-bottom: 22rpx;
}

.month-card,
.detail-card {
  border: 2rpx solid #e1e9ee;
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(20, 24, 33, 0.06);
}

.month-card {
  padding: 24rpx;
}

.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.month-btn {
  width: 66rpx;
  height: 66rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef5f7;
  color: #141821;
  font-size: 42rpx;
}

.month-title {
  color: #141821;
  font-size: 32rpx;
  font-weight: 760;
}

.week-row,
.day-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
}

.week-cell {
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #66717d;
  font-size: 22rpx;
}

.day-cell {
  position: relative;
  height: 78rpx;
  margin: 4rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #141821;
  font-size: 25rpx;
}

.day-cell.today {
  border: 2rpx solid #dbe4e7;
}

.day-cell.active {
  background: #141821;
  color: #ffffff;
  font-weight: 760;
}

.empty-cell {
  color: transparent;
}

.record-dot {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 8rpx;
  height: 8rpx;
  margin-left: -4rpx;
  border-radius: 50%;
  background: #d8b96a;
}

.day-cell.active .record-dot {
  background: #ffffff;
}

.detail-card {
  margin-top: 24rpx;
  padding: 26rpx;
}

.detail-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-date {
  color: #141821;
  font-size: 31rpx;
  font-weight: 760;
}

.detail-summary {
  margin-top: 8rpx;
  color: #66717d;
  font-size: 24rpx;
}

.outfit-canvas {
  width: 640rpx;
  height: 840rpx;
  margin-top: 22rpx;
  border: 2rpx solid #eef5f7;
  border-radius: 30rpx;
  overflow: hidden;
  background: #ffffff;
}

.record-list {
  margin-top: 18rpx;
}

.record-item {
  padding: 20rpx 0;
  border-top: 2rpx solid #eef5f7;
}

.record-main {
  color: #141821;
  font-size: 26rpx;
  font-weight: 760;
  line-height: 1.5;
}

.record-meta {
  margin-top: 8rpx;
  color: #66717d;
  font-size: 23rpx;
  line-height: 1.5;
}

.empty-text {
  margin-top: 20rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #eef5f7;
  color: #66717d;
  font-size: 25rpx;
  line-height: 1.65;
  text-align: center;
}


