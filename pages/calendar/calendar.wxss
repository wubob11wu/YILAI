.stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.stat {
  min-height: 138rpx;
  border: 2rpx solid #e2d9ca;
  border-radius: 6rpx;
  background: #fffdfa;
  padding: 20rpx;
}

.stat-num {
  color: #1d1c1a;
  font-size: 42rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 8rpx;
  color: #817b70;
  font-size: 22rpx;
}

.rank-row,
.record {
  padding: 18rpx 0;
  border-bottom: 2rpx solid #eee6d9;
}

.rank-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.rank-row:last-child,
.record:last-child {
  border-bottom: 0;
}

.rank-name,
.record-date {
  font-weight: 700;
}

.rank-meta,
.record-meta {
  margin-top: 8rpx;
  color: #817b70;
  font-size: 22rpx;
}

.rank-count {
  color: #8a6a38;
  font-weight: 700;
}

.record-items {
  margin-top: 10rpx;
  line-height: 1.5;
}

.small {
  padding: 40rpx 0;
}
