.profile {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.profile-name {
  color: #141821;
  font-size: 34rpx;
  font-weight: 760;
}

.setting-row {
  min-height: 132rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #eef5f7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.setting-row:last-child {
  border-bottom: 0;
}

.setting-title {
  color: #141821;
  font-weight: 760;
}

.setting-desc,
.roadmap {
  margin-top: 8rpx;
  color: #66717d;
  font-size: 24rpx;
  line-height: 1.55;
}

