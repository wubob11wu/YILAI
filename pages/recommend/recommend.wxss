.recommend-page {
  min-height: 100vh;
  padding: 24rpx 28rpx 56rpx;
  background: #f6f2ea;
}

.weather-bar {
  padding: 26rpx 28rpx;
  border: 2rpx solid #e2d9ca;
  border-radius: 18rpx;
  background: #fffdfa;
  box-shadow: 0 12rpx 32rpx rgba(50, 42, 31, 0.06);
}

.weather-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #1d1c1a;
  font-size: 34rpx;
  font-weight: 700;
}

.weather-tip {
  margin-top: 10rpx;
  color: #817b70;
  font-size: 24rpx;
}

.scene-strip {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.scene-chip {
  min-width: 104rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border: 2rpx solid #ded4c4;
  border-radius: 32rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #5a554c;
  background: #fffdfa;
  font-size: 25rpx;
}

.scene-chip.active {
  border-color: #1d1c1a;
  background: #1d1c1a;
  color: #fffdfa;
}

.scene-chip.more {
  color: #8a6a38;
}

.outfit-showcase {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 2rpx solid #e2d9ca;
  border-radius: 18rpx;
  background: #fffdfa;
}

.missing {
  margin-bottom: 16rpx;
  color: #9e6a20;
  font-size: 24rpx;
}

.piece-row + .piece-row {
  margin-top: 18rpx;
}

.piece-image {
  width: 100%;
  height: 300rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #eee5d6;
}

.piece-image image {
  width: 100%;
  height: 100%;
}

.piece-placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a6a38;
  font-size: 38rpx;
  font-weight: 700;
}

.piece-caption {
  margin-top: 10rpx;
  color: #4a4640;
  font-size: 24rpx;
  text-align: center;
}

.color-section {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.color-pill {
  height: 58rpx;
  padding: 0 18rpx;
  border: 2rpx solid #ded4c4;
  border-radius: 29rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #fffdfa;
  color: #3b3833;
  font-size: 24rpx;
}

.color-dot {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid rgba(29, 28, 26, 0.16);
  border-radius: 50%;
}

.reason-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 2rpx solid #e2d9ca;
  border-radius: 18rpx;
  background: #fffdfa;
}

.reason-title {
  margin-bottom: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.reason-line {
  color: #4a4640;
  font-size: 25rpx;
  line-height: 1.7;
}

.action-area {
  margin-top: 20rpx;
}

.wear-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1d1c1a;
  color: #fffdfa;
  font-size: 30rpx;
  font-weight: 700;
}

.wear-btn.confirmed {
  background: #8a6a38;
}

.calendar-link {
  margin-top: 18rpx;
  color: #8a6a38;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.secondary-actions {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.change-btn,
.dislike-btn {
  height: 82rpx;
  border-radius: 41rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.change-btn {
  border: 2rpx solid #cfc4b4;
  color: #1d1c1a;
  background: #fffdfa;
}

.dislike-btn {
  color: #817b70;
}

.panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10;
  background: rgba(29, 28, 26, 0.28);
}

.scene-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 11;
  max-height: 74vh;
  padding: 18rpx 28rpx 40rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #fffdfa;
  transform: translateY(110%);
  transition: transform 180ms ease;
}

.scene-panel.open {
  transform: translateY(0);
}

.panel-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 4rpx;
  background: #d8ccbb;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
}

.scene-group {
  margin-top: 24rpx;
}

.scene-group-title {
  margin-bottom: 12rpx;
  color: #817b70;
  font-size: 24rpx;
}

.scene-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.panel-scene {
  height: 68rpx;
  border: 2rpx solid #ded4c4;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4a4640;
  font-size: 24rpx;
}

.panel-scene.active {
  border-color: #1d1c1a;
  background: #1d1c1a;
  color: #fffdfa;
}
