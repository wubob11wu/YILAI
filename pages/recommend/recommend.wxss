.recommend-page {
  min-height: 100vh;
  padding: 34rpx 30rpx 64rpx;
  background: #f7fafb;
}

.recommend-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 22rpx;
}

.eyebrow {
  margin-bottom: 8rpx;
  color: #141821;
  font-size: 22rpx;
  font-weight: 800;
}

.weather-chip {
  min-height: 66rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #ffffff;
  color: #141821;
  font-size: 24rpx;
  font-weight: 760;
  white-space: nowrap;
  box-shadow: 0 12rpx 30rpx rgba(20, 24, 33, 0.06);
}

.weather-notice {
  margin: -10rpx 0 20rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid rgba(20, 24, 33, 0.10);
  border-radius: 22rpx;
  background: #eef7fb;
  color: #4d5965;
  font-size: 23rpx;
  line-height: 1.45;
}

.scene-strip {
  margin: 0 -30rpx;
  padding: 0 30rpx 22rpx;
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.scene-chip {
  min-width: 112rpx;
  height: 66rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #66717d;
  font-size: 25rpx;
  font-weight: 760;
}

.scene-chip.active {
  border-color: #141821;
  background: #141821;
  color: #ffffff;
}

.scene-chip.more {
  border-color: #d8b96a;
  background: #fffaf0;
  color: #7b652d;
}

.outfit-showcase {
  position: relative;
  margin-top: 4rpx;
  padding: 28rpx;
  border-radius: 42rpx;
  background: #141821;
  color: #ffffff;
  box-shadow: 0 30rpx 70rpx rgba(20, 24, 33, 0.22);
}

.showcase-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.showcase-kicker {
  color: rgba(255, 255, 255, 0.62);
  font-size: 23rpx;
  font-weight: 760;
}

.showcase-title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 52rpx;
  font-weight: 820;
  line-height: 1.05;
  letter-spacing: 0;
}

.showcase-temp {
  min-width: 96rpx;
  height: 66rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d8b96a;
  color: #141821;
  font-size: 25rpx;
  font-weight: 820;
}

.weather-tip.dark {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
  line-height: 1.55;
}

.missing {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(232, 184, 176, 0.18);
  color: #f3d7d2;
  font-size: 24rpx;
  line-height: 1.5;
}

.piece-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.piece-card {
  min-width: 0;
}

.piece-0 {
  grid-column: 1 / span 2;
}

.piece-image {
  width: 100%;
  height: 270rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background: #eef5f7;
}

.piece-0 .piece-image {
  height: 430rpx;
}

.piece-image image {
  width: 100%;
  height: 100%;
}

.piece-placeholder {
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(145deg, rgba(216, 185, 106, 0.13), rgba(255, 255, 255, 0.84)),
    #eef5f7;
  color: #141821;
  font-size: 40rpx;
  font-weight: 820;
}

.piece-placeholder::before {
  content: "";
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  top: 32rpx;
  height: 2rpx;
  background: rgba(216, 185, 106, 0.28);
}

.piece-placeholder text {
  position: relative;
  z-index: 1;
}

.piece-caption {
  margin-top: 12rpx;
  color: #ffffff;
}

.piece-role {
  color: rgba(255, 255, 255, 0.52);
  font-size: 21rpx;
  font-weight: 760;
}

.piece-name {
  margin-top: 4rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 760;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.showcase-footer {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  font-weight: 760;
}

.color-section {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.color-pill {
  min-height: 58rpx;
  padding: 0 18rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #ffffff;
  color: #4d5965;
  font-size: 24rpx;
  font-weight: 700;
}

.color-dot {
  width: 30rpx;
  height: 30rpx;
  border: 2rpx solid rgba(20, 24, 33, 0.14);
  border-radius: 50%;
}

.reason-card {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  border: 2rpx solid #e1e9ee;
  box-shadow: 0 18rpx 48rpx rgba(20, 24, 33, 0.06);
}

.reason-title {
  margin-bottom: 14rpx;
  color: #141821;
  font-size: 30rpx;
  font-weight: 820;
}

.reason-line {
  position: relative;
  padding-left: 24rpx;
  color: #4d5965;
  font-size: 25rpx;
  line-height: 1.72;
}

.reason-line::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #141821;
}

.action-area {
  margin-top: 24rpx;
  padding: 18rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 34rpx;
  background: #ffffff;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 18rpx 48rpx rgba(20, 24, 33, 0.06);
}

.action-btn {
  width: 100%;
  min-width: 0;
  height: 86rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 27rpx;
  font-weight: 820;
  line-height: 1;
  white-space: nowrap;
}

.action-btn::after {
  border: 0;
}

.primary-action {
  height: 92rpx;
  background: #141821;
  color: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(20, 24, 33, 0.16);
}

.primary-action.confirmed {
  background: #141821;
}

.action-btn[disabled] {
  opacity: 0.48;
}

.calendar-link {
  margin-top: 18rpx;
  color: #141821;
  font-size: 26rpx;
  font-weight: 760;
  text-align: center;
}

.secondary-actions {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.secondary-action {
  border: 2rpx solid #e1e9ee;
  color: #141821;
  background: #f7fafb;
}

.panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10;
  background: rgba(20, 24, 33, 0.28);
}

.scene-panel,
.tune-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 11;
  max-height: 76vh;
  padding: 18rpx 30rpx 44rpx;
  border-radius: 36rpx 36rpx 0 0;
  background: #ffffff;
  transform: translateY(110%);
  transition: transform 220ms ease;
}

.scene-panel.open,
.tune-panel.open {
  transform: translateY(0);
}

.panel-handle {
  width: 76rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #dbe4e7;
}

.panel-title {
  color: #141821;
  font-size: 34rpx;
  font-weight: 820;
}

.scene-group {
  margin-top: 26rpx;
}

.scene-group-title {
  margin-bottom: 14rpx;
  color: #66717d;
  font-size: 24rpx;
}

.scene-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.panel-scene {
  height: 70rpx;
  border: 2rpx solid #e1e9ee;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4d5965;
  font-size: 24rpx;
}

.panel-scene.active {
  border-color: #141821;
  background: #141821;
  color: #ffffff;
}

.tune-list {
  margin-top: 20rpx;
}

.tune-item {
  min-height: 104rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #eef5f7;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  color: #141821;
  font-size: 28rpx;
  font-weight: 820;
}

.tune-item:last-child {
  border-bottom: 0;
}

.tune-desc {
  color: #66717d;
  font-size: 23rpx;
  font-weight: 400;
  line-height: 1.45;
}


