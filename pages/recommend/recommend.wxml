<view class="page">
  <view class="topbar">
    <view>
      <view class="title">今日推荐</view>
      <view class="subtitle">结合天气、季节和你的风格偏好</view>
    </view>
    <button class="primary-btn" bindtap="refresh">刷新</button>
  </view>

  <view class="panel weather">
    <view>
      <view class="weather-city">{{weather.city}}</view>
      <view class="weather-summary">{{weather.temp}}度 · {{weather.summary}}</view>
    </view>
    <view class="weather-data">
      <text>降水 {{weather.rainChance}}%</text>
      <text>风力 {{weather.wind}}级</text>
    </view>
  </view>

  <view class="section panel">
    <view class="section-title">风格偏好</view>
    <view class="chip-row">
      <view wx:for="{{styleOptions}}" wx:key="name" class="chip {{item.active ? 'active' : ''}}" data-value="{{item.name}}" bindtap="togglePreference">{{item.name}}</view>
    </view>
    <view class="inline-add">
      <input class="input inline-add-input" placeholder="自定义风格，如 松弛感、Y2K、轻户外" value="{{customStyleText}}" bindinput="onCustomStyle" />
      <button class="ghost-btn inline-add-btn" bindtap="addCustomStyle">添加</button>
    </view>
  </view>

  <view class="section panel">
    <view class="section-title">推荐组合</view>
    <view wx:if="{{recommendation.missingText}}" class="missing">缺少 {{recommendation.missingText}}，推荐可能不完整。</view>
    <view class="outfit">
      <view class="outfit-piece">
        <view class="piece-label">上衣</view>
        <view class="piece-name">{{recommendation.top ? recommendation.top.name : '暂无'}}</view>
      </view>
      <view class="outfit-piece">
        <view class="piece-label">下装</view>
        <view class="piece-name">{{recommendation.pants ? recommendation.pants.name : '暂无'}}</view>
      </view>
      <view class="outfit-piece">
        <view class="piece-label">鞋履</view>
        <view class="piece-name">{{recommendation.shoes ? recommendation.shoes.name : '暂无'}}</view>
      </view>
    </view>
    <view class="reason">{{recommendation.reason}}</view>
    <view class="palette">配色：{{recommendation.palette}}</view>
    <button class="primary-btn full-btn" bindtap="markToday" disabled="{{!recommendation.itemIds.length}}">标记为今日穿搭</button>
  </view>
</view>
