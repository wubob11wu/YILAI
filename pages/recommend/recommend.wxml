<view class="recommend-page">
  <view class="recommend-header">
    <view>
      <view class="eyebrow">今日搭配</view>
      <view class="title">今天穿什么</view>
    </view>
    <view class="weather-chip">
      <text>{{weather.city}}</text>
      <text wx:if="{{weather.tempText}}">{{weather.tempText}}</text>
    </view>
  </view>
  <view wx:if="{{weather.isFallback}}" class="weather-notice">
    {{weather.city}}，{{weather.displayText}}
  </view>

  <view class="scene-strip">
    <view
      wx:for="{{quickSceneOptions}}"
      wx:key="name"
      class="scene-chip {{item.active ? 'active' : ''}}"
      data-name="{{item.name}}"
      bindtap="selectScene"
    >{{item.name}}</view>
    <view class="scene-chip more" bindtap="openScenePanel">更多场景</view>
  </view>

  <view class="outfit-showcase">
    <view class="showcase-top">
      <view>
        <view class="showcase-kicker">{{selectedSceneName}} · {{weather.displayText}}</view>
        <view class="showcase-title">就穿这套</view>
      </view>
      <view class="showcase-temp">{{weather.tempText || '默认'}}</view>
    </view>
    <view class="weather-tip dark">{{weather.dressingTip}}</view>

    <view wx:if="{{recommendation.missingText}}" class="missing">缺少 {{recommendation.missingText}}，推荐可能不完整。</view>

    <view class="piece-grid">
      <view wx:for="{{recommendation.pieces}}" wx:for-index="pieceIndex" wx:key="role" class="piece-card piece-{{pieceIndex}}">
        <view class="piece-image">
          <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" />
          <view wx:else class="piece-placeholder">
            <text>{{item.role}}</text>
          </view>
        </view>
        <view class="piece-caption">
          <view class="piece-role">{{item.role}}</view>
          <view class="piece-name">{{item.name}}</view>
        </view>
      </view>
    </view>

    <view class="showcase-footer">
      <text>{{recommendation.palette}}</text>
      <text>{{recommendation.itemIds.length}} 件单品</text>
    </view>
  </view>

  <view class="color-section">
    <view
      wx:for="{{recommendation.colorTags}}"
      wx:key="id"
      class="color-pill"
    >
      <view class="color-dot" style="background: {{item.hex}};"></view>
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="reason-card">
    <view class="reason-title">推荐理由</view>
    <view wx:for="{{recommendation.reasonLines}}" wx:key="*this" class="reason-line">{{item}}</view>
  </view>

  <view class="action-area">
    <button class="action-btn primary-action {{confirmed ? 'confirmed' : ''}}" bindtap="confirmOutfit" disabled="{{!canConfirm}}">
      {{confirmed ? '已确认' : '就穿这套'}}
    </button>
    <view wx:if="{{showCalendarLink}}" class="calendar-link" bindtap="goCalendar">查看日历</view>
    <view class="secondary-actions">
      <button class="action-btn secondary-action" bindtap="changeOutfit">换一套</button>
      <button class="action-btn secondary-action" bindtap="openTunePanel">微调</button>
    </view>
  </view>

  <view wx:if="{{scenePanelOpen}}" class="panel-mask" bindtap="closeScenePanel"></view>
  <view class="scene-panel {{scenePanelOpen ? 'open' : ''}}">
    <view class="panel-handle"></view>
    <view class="panel-title">选择场景</view>
    <view wx:for="{{sceneGroups}}" wx:key="group" class="scene-group">
      <view class="scene-group-title">{{item.group}}</view>
      <view class="scene-grid">
        <view
          wx:for="{{item.options}}"
          wx:for-item="scene"
          wx:key="name"
          class="panel-scene {{scene.name === selectedSceneName ? 'active' : ''}}"
          data-name="{{scene.name}}"
          bindtap="selectScene"
        >{{scene.name}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{tunePanelOpen}}" class="panel-mask" bindtap="closeTunePanel"></view>
  <view class="tune-panel {{tunePanelOpen ? 'open' : ''}}">
    <view class="panel-handle"></view>
    <view class="panel-title">微调这套穿搭</view>
    <view class="tune-list">
      <view class="tune-item" data-target="top" bindtap="changePiece">
        <text>换上装</text>
        <text class="tune-desc">保留下装和鞋子，只换上衣</text>
      </view>
      <view class="tune-item" data-target="pants" bindtap="changePiece">
        <text>换下装</text>
        <text class="tune-desc">保留上装和鞋子，只换裤裙</text>
      </view>
      <view class="tune-item" data-target="shoes" bindtap="changePiece">
        <text>换鞋饰</text>
        <text class="tune-desc">保留上下装，只换鞋子</text>
      </view>
    </view>
  </view>
</view>
