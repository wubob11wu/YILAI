<view class="recommend-page">
  <view class="weather-bar">
    <view class="weather-main">
      <text>{{weather.city}}</text>
      <text>{{weather.temp}}℃</text>
      <text>{{weather.text}}</text>
      <text>{{weather.icon}}</text>
    </view>
    <view class="weather-tip">{{weather.dressingTip}}</view>
  </view>

  <view class="scene-strip">
    <view
      wx:for="{{quickSceneOptions}}"
      wx:key="name"
      class="scene-chip {{item.active ? 'active' : ''}}"
      data-name="{{item.name}}"
      bindtap="selectScene"
    >{{item.name}}</view>
    <view class="scene-chip more" bindtap="openScenePanel">更多+</view>
  </view>

  <view class="outfit-showcase">
    <view wx:if="{{recommendation.missingText}}" class="missing">缺少 {{recommendation.missingText}}，推荐可能不完整。</view>
    <view wx:for="{{recommendation.pieces}}" wx:key="role" class="piece-row">
      <view class="piece-image">
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" />
        <view wx:else class="piece-placeholder">{{item.role}}</view>
      </view>
      <view class="piece-caption">{{item.name}}</view>
    </view>
  </view>

  <view class="color-section">
    <view
      wx:for="{{recommendation.colorTags}}"
      wx:key="id"
      class="color-pill"
    >
      <view class="color-dot" style="background: {{item.hex}};"></view>
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="reason-card">
    <view class="reason-title">推荐理由</view>
    <view wx:for="{{recommendation.reasonLines}}" wx:key="*this" class="reason-line">✅ {{item}}</view>
  </view>

  <view class="action-area">
    <button class="wear-btn {{confirmed ? 'confirmed' : ''}}" bindtap="confirmOutfit" disabled="{{!canConfirm}}">
      {{confirmed ? '已确认 ✓' : '👍 就穿这套'}}
    </button>
    <view wx:if="{{showCalendarLink}}" class="calendar-link" bindtap="goCalendar">查看日历</view>
    <view class="secondary-actions">
      <button class="change-btn" bindtap="changeOutfit">换一套</button>
      <button class="dislike-btn" bindtap="dislikeOutfit">不喜欢</button>
    </view>
  </view>

  <view wx:if="{{scenePanelOpen}}" class="panel-mask" bindtap="closeScenePanel"></view>
  <view class="scene-panel {{scenePanelOpen ? 'open' : ''}}">
    <view class="panel-handle"></view>
    <view class="panel-title">选择场景</view>
    <view wx:for="{{sceneGroups}}" wx:key="group" class="scene-group">
      <view class="scene-group-title">{{item.group}}</view>
      <view class="scene-grid">
        <view
          wx:for="{{item.options}}"
          wx:for-item="scene"
          wx:key="name"
          class="panel-scene {{scene.name === selectedSceneName ? 'active' : ''}}"
          data-name="{{scene.name}}"
          bindtap="selectScene"
        >{{scene.name}}</view>
      </view>
    </view>
  </view>
</view>
