<view class="closet-page">
  <view class="closet-header">
    <image class="header-bg" src="/assets/closet-hero/header.jpg" mode="aspectFill" />
    <view class="header-shade"></view>
    <view class="header-copy">
      <view class="eyebrow">YILAI WARDROBE</view>
      <view class="title">我的衣橱</view>
    </view>
    <view class="header-actions">
      <view class="limit-text">{{itemLimitText}}</view>
      <view class="tool-row">
        <button class="tool-btn" aria-label="搜索" bindtap="toggleSearch">
          <view class="tool-icon search-icon"></view>
        </button>
        <button class="tool-btn" aria-label="筛选" bindtap="toggleFilter">
          <view class="tool-icon filter-icon">
            <view></view>
            <view></view>
            <view></view>
          </view>
        </button>
        <button class="tool-btn add" aria-label="添加" bindtap="addItem">
          <view class="tool-icon plus-icon">+</view>
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{searchOpen}}" class="search-wrap">
    <input class="search-input" placeholder="搜索衣物名称" value="{{keyword}}" bindinput="onKeyword" focus="{{searchOpen}}" />
    <button class="search-clear" bindtap="clearKeyword">取消</button>
  </view>

  <view wx:if="{{filterOpen}}" class="filter-panel">
    <view class="filter-top">
      <view class="filter-title">高级筛选</view>
      <button class="filter-reset" bindtap="clearAdvancedFilters">恢复默认</button>
    </view>

    <view class="filter-row-title">季节</view>
    <view class="filter-chip-row">
      <view wx:for="{{seasonOptions}}" wx:key="name" class="filter-chip {{item.active ? 'active' : ''}}" data-field="selectedSeasons" data-value="{{item.name}}" bindtap="toggleMulti">{{item.name}}</view>
      <view class="filter-chip helper" bindtap="showAllSeasons">全季节</view>
    </view>

    <view class="filter-row-title">颜色</view>
    <view class="filter-chip-row">
      <view wx:for="{{colorOptions}}" wx:key="name" class="filter-chip {{item.active ? 'active' : ''}}" data-field="selectedColors" data-value="{{item.name}}" bindtap="toggleMulti">{{item.name}}</view>
    </view>

    <view class="filter-row-title">主风格</view>
    <view class="filter-chip-row">
      <view wx:for="{{styleOptions}}" wx:key="name" class="filter-chip {{item.active ? 'active' : ''}}" data-field="selectedStyles" data-value="{{item.name}}" bindtap="toggleMulti">{{item.name}}</view>
    </view>
  </view>

  <view class="closet-shell">
    <scroll-view class="side-nav" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{categories}}"
        wx:key="name"
        class="side-item {{item.active ? 'active' : ''}}"
        data-value="{{item.name}}"
        bindtap="setCategory"
      >
        <image class="side-thumb" src="{{item.image}}" mode="aspectFill" />
        <text class="side-name">{{item.name}}</text>
        <text class="side-count">{{item.count}}</text>
      </view>
    </scroll-view>

    <view class="closet-content">
      <view class="content-head">
        <view>
          <view class="content-title">{{currentCategoryTitle}}</view>
          <view class="content-subtitle">{{currentCategoryCount}} 件单品 · {{defaultSeasonText}}</view>
        </view>
      </view>

      <view class="category-hero">
        <image class="hero-image" src="{{currentHero.image}}" mode="aspectFill" />
        <view class="hero-overlay">
          <view class="hero-kicker">{{currentHero.title}}</view>
          <view class="hero-desc">{{currentHero.desc}}</view>
        </view>
      </view>

      <view class="subcategory-wrap">
        <view wx:if="{{subcategoryMenuOpen}}" class="subcategory-menu-backdrop" bindtap="closeSubcategoryMenu"></view>
        <view class="subcategory-row {{hasHiddenSubcategories ? 'has-more' : ''}}">
          <view
            wx:for="{{visibleSubcategoryOptions}}"
            wx:key="name"
            class="subcategory-chip {{item.active ? 'active' : ''}}"
            data-value="{{item.name}}"
            bindtap="setSubcategory"
          >{{item.name}}</view>
          <view
            wx:if="{{hasHiddenSubcategories}}"
            class="subcategory-more {{subcategoryMenuOpen || hiddenSubcategoryActive ? 'active' : ''}}"
            bindtap="toggleSubcategoryMenu"
          >
            <text class="more-dot"></text>
            <text class="more-dot"></text>
            <text class="more-dot"></text>
          </view>
        </view>
        <scroll-view wx:if="{{subcategoryMenuOpen}}" class="subcategory-menu" scroll-y enhanced show-scrollbar="{{false}}" style="height: {{subcategoryMenuHeight}}rpx;">
          <view
            wx:for="{{hiddenSubcategoryOptions}}"
            wx:key="name"
            class="subcategory-chip compact {{item.active ? 'active' : ''}}"
            data-value="{{item.name}}"
            bindtap="setSubcategory"
          >{{item.name}}</view>
        </scroll-view>
      </view>

      <view class="closet-grid" wx:if="{{filteredItems.length}}">
        <view wx:for="{{filteredItems}}" wx:key="id" class="item-card" data-id="{{item.id}}" bindtap="editItem" bindlongpress="confirmDelete">
          <view class="photo-wrap">
            <image wx:if="{{item.image}}" class="photo" mode="aspectFill" src="{{item.image}}" />
            <view wx:else class="photo-placeholder">{{item.subcategory}}</view>
          </view>
          <view class="item-info">
            <view class="item-name">{{item.name}}</view>
            <view class="item-meta">{{item.color}} · {{item.mainStyle}}</view>
          </view>
        </view>
      </view>

      <view wx:else class="empty">
        <view class="empty-title">{{items.length ? '没有找到相关衣物' : '这一格衣橱还是空的'}}</view>
        <view class="empty-desc">{{items.length ? '试试切换分类、清空搜索或调整筛选。' : '添加几件常穿单品后，推荐会更准确。'}}</view>
        <button class="empty-action" bindtap="addItem">添加衣物</button>
      </view>
    </view>
  </view>
</view>
