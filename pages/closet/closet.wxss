.search {
  margin-bottom: 22rpx;
}

.filter-block + .filter-block {
  margin-top: 18rpx;
}

.item-card {
  min-height: 410rpx;
  border: 2rpx solid #e2d9ca;
  border-radius: 6rpx;
  background: #fffdfa;
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(50, 42, 31, 0.05);
}

.photo-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #eee5d6;
}

.photo {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a6a38;
  font-size: 34rpx;
  font-weight: 700;
}

.item-name {
  padding: 16rpx 16rpx 0;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-meta {
  padding: 8rpx 16rpx 0;
  color: #817b70;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mini-tags {
  min-height: 58rpx;
  padding: 12rpx 16rpx 16rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.mini-tags text {
  max-width: 150rpx;
  padding: 6rpx 10rpx;
  border-radius: 6rpx;
  background: #f1eadf;
  color: #5a554c;
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
