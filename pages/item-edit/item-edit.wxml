<view class="edit-page">
  <view class="edit-header">
    <view class="title">{{isEdit ? '编辑衣物' : '添加衣物'}}</view>
  </view>

  <view class="edit-section">
    <view class="required-title">必填 1 · 单品图片</view>
    <view class="image-area" bindtap="chooseImage">
      <image wx:if="{{form.image}}" class="preview" mode="aspectFill" src="{{form.image}}" />
      <view wx:else class="upload-hint">拍照 / 相册选择</view>
    </view>
    <button class="secondary-btn full-btn" bindtap="chooseImage">拍照 / 相册选择</button>
  </view>

  <view class="edit-section">
    <view class="required-title">必填 2 · 二级品类</view>
    <view class="field-label">大品类</view>
    <view class="chip-row">
      <view wx:for="{{categoryOptions}}" wx:key="name" class="select-chip {{item.active ? 'active' : ''}}" data-value="{{item.name}}" bindtap="setCategory">{{item.name}}</view>
    </view>
    <view class="field-label">细品类</view>
    <view class="chip-row">
      <view wx:for="{{subcategoryOptions}}" wx:key="name" class="select-chip {{item.active ? 'active' : ''}}" data-value="{{item.name}}" bindtap="setSubcategory">{{item.name}}</view>
    </view>
  </view>

  <view class="edit-section">
    <view class="required-title">必填 3 · 颜色选择</view>
    <view class="auto-line">请选择主色，系统不会猜测图片内容。</view>
    <view class="color-grid">
      <view wx:for="{{colorOptions}}" wx:key="name" class="color-chip {{item.active ? 'active' : ''}}" data-value="{{item.name}}" bindtap="setColor">{{item.display}}</view>
    </view>
  </view>

  <view class="edit-section">
    <view class="required-title">必填 4 · 衣物名称</view>
    <input class="edit-input" value="{{form.name}}" bindinput="onNameInput" placeholder="系统自动生成，可修改" />
  </view>

  <view class="edit-section">
    <view class="required-title">必填 5 · 适用季节</view>
    <view class="auto-line">根据品类建议季节：{{autoSeasonText}}</view>
    <view class="chip-row">
      <view wx:for="{{seasonOptions}}" wx:key="name" class="select-chip {{item.active ? 'active' : ''}}" data-value="{{item.name}}" bindtap="toggleSeason">{{item.name}}</view>
    </view>
  </view>

  <view class="more-toggle" bindtap="toggleMore">
    <text>更多可选属性</text>
    <text>{{moreOpen ? '▲' : '▼'}}</text>
  </view>

  <view wx:if="{{moreOpen}}" class="edit-section">
    <view class="field-label">选填 1 · 主风格（系统自动推断）</view>
    <view class="chip-row">
      <view wx:for="{{mainStyleOptions}}" wx:key="name" class="select-chip {{item.active ? 'active' : ''}}" data-value="{{item.name}}" bindtap="setMainStyle">{{item.name}}</view>
    </view>

    <view class="field-label">选填 2 · 风格属性标签（最多 3 个）</view>
    <view class="chip-row">
      <view wx:for="{{attributeOptions}}" wx:key="name" class="select-chip {{item.active ? 'active' : ''}}" data-value="{{item.name}}" bindtap="toggleAttribute">{{item.name}}</view>
    </view>

    <view class="field-label">选填 3 · 备注</view>
    <textarea class="note-input" maxlength="50" value="{{form.note}}" bindinput="onNoteInput" placeholder="最多 50 字，例如：适合重要会议、容易皱" />
  </view>

  <view class="bottom-space"></view>

  <view class="bottom-actions">
    <button wx:if="{{isEdit}}" class="delete-btn" bindtap="remove">删除</button>
    <button class="save-btn" bindtap="save">保存</button>
  </view>
</view>
